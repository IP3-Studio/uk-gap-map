# Copy to .env on the server and fill in. Never commit the real .env.
# Random 64-char string: openssl rand -hex 32
SECRET=change-me
# Let's Encrypt registration email (expiry notices only)
ACME_EMAIL=you@example.org
# Admin user id: log in once on the forum, copy your user id from the profile,
# paste it here, then docker compose up -d to restart. Until then leave blank.
ADMIN_ID=
# Basic-auth password for the admin API (backups, exports)
ADMIN_PASSWD=change-me-too
# Where moderation notifications go
ADMIN_EMAIL=you@example.org
