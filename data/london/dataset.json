{"meta":{"title":"London Gap Map — borough dataset v2","generated":"2026-07-19","geography":"33 London local authorities (32 boroughs + City of London), ONS codes E09*","scoring":"Each indicator is percentile-ranked across the 33 LAs (100 = highest relative gap). Inverted indicators (lower raw value = bigger gap): att8, recycling_pct, hle_male, youth_spend_change_pct. Theme gap scores are the mean of member indicator ranks; overall_gap_score is the mean of the five theme scores. Missing values are null.","themes":{"youth":["neet_nk_pct","att8","pa_pct","fsm_pct","fte_rate_100k"],"housing":["ta_per_1000","duty_per_1000","waiting_per_1000","rough_sleep_rate_100k","overcrowded_pct","crime_per_1000"],"environment":["flytip_per_1000","recycling_pct"],"living":["fuel_poor_pct","digital_exclusion_risk"],"health":["hle_male","smoking_pct"]},"indicators":{"neet_nk_pct":{"label":"16-17 NEET or activity unknown","unit":"%","source":"DfE, Participation in education, training and NEET 16-17 by LA, 2024/25"},"att8":{"label":"Average Attainment 8 score","unit":"score","source":"DfE, Key stage 4 performance 2024/25 (revised)"},"pa_pct":{"label":"Persistent absence (>10% sessions)","unit":"% pupils","source":"DfE, Pupil absence in schools in England, 2024/25"},"fsm_pct":{"label":"Pupils eligible for free school meals","unit":"% pupils","source":"DfE, Schools, pupils and their characteristics, Jan 2026"},"fte_rate_100k":{"label":"First-time entrants to youth justice","unit":"per 100k aged 10-17","source":"YJB/MoJ, Youth Justice Statistics 2024/25"},"youth_spend_change_pct":{"label":"Council youth services spend change 2015/16-2024/25","unit":"% nominal","source":"DfE S251 outturn (computed, total services for young people rows)"},"ta_per_1000":{"label":"Households in temporary accommodation","unit":"per 1,000 households","source":"MHCLG statutory homelessness detailed LA tables, 31 Dec 2025"},"children_ta_per_1000hh":{"label":"Children in temporary accommodation","unit":"per 1,000 ho